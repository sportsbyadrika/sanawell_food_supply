generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)
  slug String @unique(map: "slug") @db.VarChar(100)

  @@map("roles")
}

model Agency {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(150)
  contact_email   String           @db.VarChar(150)
  status          agencies_status? @default(pending)
  created_at      DateTime         @default(now()) @db.Timestamp(0)
  contact_number  String           @db.VarChar(20)
  whatsapp_number String?          @db.VarChar(20)
  products        Product[]

  @@map("agencies")
}

model User {
  id                     Int           @id @default(autoincrement())
  agency_id              Int?
  role_id                Int
  name                   String        @db.VarChar(150)
  email                  String        @unique(map: "email") @db.VarChar(150)
  mobile                 String        @db.VarChar(20)
  password_hash          String        @map("password_hash") @db.VarChar(255)
  first_login            Boolean?      @default(true)
  status                 users_status? @default(active)
  created_at             DateTime      @default(now()) @db.Timestamp(0)
  password_reset_token   String?       @db.VarChar(255)
  password_reset_expires DateTime?     @db.DateTime(0)
  last_login             DateTime?     @db.DateTime(0)
  last_login_ip          String?       @db.VarChar(45)

  @@index([agency_id], map: "agency_id")
  @@index([role_id], map: "role_id")
  @@map("users")
}

model Product {
  id          Int              @id @default(autoincrement())
  agency_id   Int
  name        String           @db.VarChar(150)
  description String?          @db.VarChar(255)
  variant     String           @db.VarChar(100)
  image       String?          @db.VarChar(255)
  status      products_status? @default(active)
  created_at  DateTime         @default(now()) @db.Timestamp(0)
  bill_items  bill_items[]
  agency      Agency           @relation(fields: [agency_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "products_ibfk_1")

  @@index([agency_id], map: "agency_id")
  @@map("products")
}

model Customer {
  id          Int      @id @default(autoincrement())
  agency_id   Int
  name        String   @db.VarChar(150)
  mobile      String   @db.VarChar(20)
  address     String   @db.Text
  latitude    Decimal  @db.Decimal(10, 7)
  longitude   Decimal  @db.Decimal(10, 7)
  category_id Int
  route_id    Int?
  status      Int?     @default(1) @db.TinyInt
  created_at  DateTime @default(now()) @db.Timestamp(0)
  whatsapp    String?  @db.VarChar(20)
  route_order Int?     @default(0)
  bills       Bill[]

  @@index([agency_id], map: "idx_agency")
  @@index([category_id], map: "idx_category")
  @@index([latitude, longitude], map: "idx_location")
  @@map("customers")
}

model Route {
  id          Int          @id @default(autoincrement())
  agency_id   Int
  name        String?      @db.VarChar(100)
  type        routes_type?
  description String?      @db.Text
  driver_id   Int?
  status      Int?         @default(1) @db.TinyInt
  created_at  DateTime     @default(now()) @db.Timestamp(0)
  vehicle_id  Int?

  @@map("routes")
}

model DeliveryOrder {
  id              Int             @id @default(autoincrement())
  route_id        Int
  driver_id       Int?
  vehicle_id      Int?
  customer_id     Int
  order_no        Int
  delivery_date   DateTime        @db.Date
  trip_start_time DateTime?       @db.Time(0)
  status          DeliveryStatus? @default(pending)
  reason          String?         @db.Text
  delivered_at    DateTime?       @db.DateTime(0)
  created_at      DateTime        @default(now()) @db.Timestamp(0)
  remarks         String?         @db.Text
  failure_reason  String?         @db.VarChar(255)
  failure_remarks String?         @db.Text
  final_amount    Decimal?        @default(0.00) @db.Decimal(10, 2)
  cancel_reason   String?         @db.Text

  @@map("delivery_orders")
}

model DeliveryOrderItem {
  id                Int     @id @default(autoincrement())
  delivery_order_id Int
  product_id        Int
  quantity          Int
  rate              Decimal @db.Decimal(10, 2)
  total_amount      Decimal @db.Decimal(10, 2)
  added_qty         Int?    @default(0)
  cancelled_qty     Int?    @default(0)

  @@map("delivery_order_items")
}

model Bill {
  id           Int          @id @default(autoincrement())
  customer_id  Int
  bill_date    DateTime     @db.Date
  total_amount Decimal      @default(0.00) @db.Decimal(10, 2)
  status       String?      @default("BILL GENERATED") @db.VarChar(50)
  created_at   DateTime     @default(now()) @db.Timestamp(0)
  final_amount Decimal?     @default(0.00) @db.Decimal(10, 2)
  route_id     Int?
  bill_from    DateTime?    @db.Date
  bill_to      DateTime?    @db.Date
  bill_type    String?      @db.VarChar(50)
  tax_amount   Decimal?     @default(0.00) @db.Decimal(10, 2)
  bill_items   bill_items[]
  customers    Customer     @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "bills_ibfk_1")

  @@index([customer_id], map: "customer_id")
  @@map("bills")
}

model Receipt {
  id               Int       @id @default(autoincrement())
  bill_id          Int?
  route_id         Int?
  receipt_date     DateTime? @db.Date
  amount           Decimal?  @db.Decimal(10, 2)
  payment_mode     String?   @db.VarChar(50)
  transaction_ref  String?   @db.VarChar(100)
  transaction_date DateTime? @db.Date
  status           String?   @db.VarChar(50)
  verified_date    DateTime? @db.DateTime(0)
  verified_user_id Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  @@map("receipts")
}

model bill_items {
  id         Int      @id @default(autoincrement())
  bill_id    Int
  product_id Int
  quantity   Int
  price      Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)
  qty        Int?
  amount     Decimal? @db.Decimal(10, 2)
  bills      Bill     @relation(fields: [bill_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "bill_items_ibfk_1")
  products   Product  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "bill_items_ibfk_2")

  @@index([bill_id], map: "bill_id")
  @@index([product_id], map: "product_id")
}

model change_requests {
  id            Int      @id @default(autoincrement())
  customer_id   Int
  product_id    Int
  request_date  DateTime @db.Date
  requested_qty Int
  normal_qty    Int
  status        Int?     @default(1) @db.TinyInt
  created_at    DateTime @default(now()) @db.Timestamp(0)
}

model customer_categories {
  id          Int                         @id @default(autoincrement())
  agency_id   Int
  name        String                      @db.VarChar(100)
  description String?                     @db.VarChar(255)
  status      customer_categories_status? @default(active)
  created_at  DateTime                    @default(now()) @db.Timestamp(0)
}

model customer_products {
  id           Int      @id @default(autoincrement())
  customer_id  Int
  product_id   Int
  quantity     Decimal  @db.Decimal(5, 2)
  route_id     Int
  created_at   DateTime @default(now()) @db.Timestamp(0)
  status       Boolean  @default(true)
  rate         Decimal  @default(0.00) @db.Decimal(10, 2)
  total_amount Decimal  @default(0.00) @db.Decimal(10, 2)

  @@index([customer_id], map: "customer_id")
  @@index([product_id], map: "product_id")
  @@index([route_id], map: "route_id")
}

model customer_type_rates {
  id               Int       @id @default(autoincrement())
  customer_type_id Int
  product_id       Int
  variant          String    @db.VarChar(100)
  rate             Decimal   @db.Decimal(10, 2)
  valid_from       DateTime  @db.Date
  valid_to         DateTime? @db.Date
  created_at       DateTime  @default(now()) @db.Timestamp(0)
}

model daily_delivery_bill {
  id                Int      @id @default(autoincrement())
  delivery_order_id Int
  product_id        Int
  qty               Int
  amount            Decimal  @db.Decimal(10, 2)
  status            String?  @default("pending") @db.VarChar(50)
  created_at        DateTime @default(now()) @db.Timestamp(0)
  reason            String?  @db.Text
  remarks           String?  @db.Text
}

model invoices {
  id           Int      @id @default(autoincrement())
  customer_id  Int
  month        Int?     @db.Year
  total_amount Decimal? @db.Decimal(10, 2)
  generated_at DateTime @default(now()) @db.Timestamp(0)
}

model route_customers {
  id             Int      @id @default(autoincrement())
  route_id       Int
  customer_id    Int
  delivery_order Int
  created_at     DateTime @default(now()) @db.Timestamp(0)
}

model user_types {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)
  code String @unique(map: "code") @db.VarChar(50)
}

model vehicles {
  id                   Int                    @id @default(autoincrement())
  agency_id            Int
  vehicle_no           String                 @unique(map: "vehicle_no") @db.VarChar(50)
  vehicle_model        String?                @db.VarChar(100)
  vehicle_company      String?                @db.VarChar(100)
  vehicle_type         vehicles_vehicle_type? @default(commercial)
  fuel_type            vehicles_fuel_type?
  registration_date    DateTime?              @db.Date
  insurance_valid_upto DateTime?              @db.Date
  status               Int?                   @default(1) @db.TinyInt
  created_at           DateTime?              @default(now()) @db.DateTime(0)
}

enum DeliveryStatus {
  pending
  delivered
  not_delivered
}

enum routes_type {
  morning
  evening
}

enum customer_categories_status {
  active
  inactive
}

enum vehicles_vehicle_type {
  commercial
  private
}

enum products_status {
  active
  inactive
}

enum vehicles_fuel_type {
  petrol
  diesel
  electric
  cng
  gas
}

enum users_status {
  active
  inactive
}

enum agencies_status {
  pending
  active
  inactive
}
